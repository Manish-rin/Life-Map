# Praan-setu Environment Variables
# Copy this file to .env and fill in the values

PORT=3001
NODE_ENV=development

# JWT — change these secrets in production!
JWT_SECRET=praansetu_jwt_secret_change_in_prod_32chars
JWT_REFRESH_SECRET=praansetu_refresh_secret_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SQLite DB path (relative to project root)
DB_PATH=./praansetu.db

# Escalation timer in milliseconds
# 90000 = 90s (production), 9000 = 9s (demo/dev)
ESCALATION_MS=9000

# For demo: OTP is always this code (dev only)
DEMO_OTP=123456
